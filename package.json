{
  "name": "deepseek-balance",
  "displayName": "DeepSeek Balance",
  "description": "在状态栏显示余额",
  "version": "0.0.2",
  "repository": {
    "type": "git",
    "url": "https://github.com/LostRoy/deepseek-balance.git"
  },
  "engines": {
    "vscode": "^1.125.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "deepseek-balance.refresh",
        "title": "DeepSeek: 刷新余额",
        "icon": "$(refresh)"
      }
    ],
    "configuration": {
      "title": "DeepSeek Balance",
      "properties": {
        "deepseekBalance.apiKey": {
          "type": "string",
          "default": "",
          "description": "你的 DeepSeek API Key，可从 platform.deepseek.com 获取"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.125.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}